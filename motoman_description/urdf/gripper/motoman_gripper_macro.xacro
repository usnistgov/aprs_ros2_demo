<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="motoman_gripper" params="
        parent
        ">

        <!-- Gripper Link -->
        <link name="motoman_gripper_base">
            <visual name="$motoman_gripper_base_visual">
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="0.05" length="0.05" />
                </geometry>
                <material name="Grey"/>
            </visual>

            <collision name="$motoman_gripper_base_collision">
                <origin xyz="0 0 -0.005" rpy="0 0 0"/>
                <geometry>
                <cylinder radius="0.05" length="0.05" />
                </geometry>
            </collision>
            
            <inertial>
                <origin xyz="0 0 -0.005" rpy="0 0 0"/>
                <mass value="0.102"/>
                <inertia ixx="0.0000647" ixy="0.0" ixz="0.0" iyy="0.0000647" iyz="0.0" izz="0.0001276"/>
            </inertial>
        </link>

        <joint name="$robot_to_gripper_base" type="fixed">
            <parent link="${parent}"/>
            <child link="motoman_gripper_base"/>
            <origin xyz="0.0 0.0 0.01" rpy="0.0 0.0 0.0"/>
        </joint>

        <link name="motoman_finger_1">
            <inertial>
            <origin
                xyz="0.022998 0.021681 -9.1584E-06"
                rpy="0 0 0" />
            <mass
                value="5" />
            <inertia
                ixx="1"
                ixy="3.7227E-06"
                ixz="1.1564E-09"
                iyy="1"
                iyz="-5.5289E-09"
                izz="1" />
            </inertial>
            <visual>
            <origin
                xyz="0 0 0"
                rpy="0 0 0" />
            <geometry>
                <box>
                    <size> 0.05 0.05 0.05 </size>
                </box>
            </geometry>
            <material
                name="">
                <color
                rgba="0.79216 0.81961 0.93333 1" />
            </material>
            </visual>
            <collision>
            <origin
                xyz="0 0 0"
                rpy="0 0 0" />
            <geometry>
                <box>
                    <size>0.05 0.05 0.05 </size>
                </box>
            </geometry>
            </collision>
        </link>
        <joint
            name="motoman_prism1"
            type="prismatic">
            <origin
            xyz="0 0 0.1621"
            rpy="1.5708 0 0" />
            <parent
            link="motoman_gripper_base" />
            <child
            link="motoman_finger_1" />
            <axis
            xyz="1 0 0" />
            <limit
            lower="0.0"
            upper="0.02"
            effort="100"
            velocity="100" />
        </joint>
        <link
            name="motoman_finger_2">
            <inertial>
            <origin
                xyz="0.022998 0.021681 -9.8018E-06"
                rpy="0 0 0" />
            <mass
                value="5" />
            <inertia
                ixx="1"
                ixy="3.7227E-06"
                ixz="1.199E-09"
                iyy="1"
                iyz="-5.7323E-09"
                izz="1" />
            </inertial>
            <visual>
            <origin
                xyz="0 0 0"
                rpy="0 0 0" />
            <geometry>
                <box>
                    <size> 0.05 0.05 0.05 </size>
                </box>
            </geometry>
            <material
                name="">
                <color
                rgba="0.79216 0.81961 0.93333 1" />
            </material>
            </visual>
            <collision>
            <origin
                xyz="0 0 0"
                rpy="0 0 0" />
            <geometry>
                <box>
                    <size> 0.05 0.05 0.05 </size>
                </box>
            </geometry>
            </collision>
        </link>
        <joint
            name="motoman_prism_2"
            type="prismatic">
            <origin
            xyz="0 0 0.1621"
            rpy="1.5708 0 3.1416" />
            <parent
            link="motoman_gripper_base" />
            <child
            link="motoman_finger_2" />
            <axis
            xyz="-1 0 0" />
            <limit
            lower="0.0"
            upper="0.02"
            effort="100"
            velocity="100" />
        </joint>
    </xacro:macro>
  
</robot>