<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="fanuc" params="parent">
   
    <!-- Joint 1 -->
    <xacro:property name="joint1upper" value="2.967"/>
    <xacro:property name="joint1lower" value="-2.967"/>
    <xacro:property name="joint1velocity" value="7.85"/>
    <xacro:property name="joint1effort" value="-1"/>

    <!-- Joint 2 -->
    <xacro:property name="joint2upper" value="2.53"/>
    <xacro:property name="joint2lower" value="-1.745"/>
    <xacro:property name="joint2velocity" value="6.63"/>
    <xacro:property name="joint2effort" value="-1"/>

    <!-- Joint 3 -->
    <xacro:property name="joint3upper" value="4.886"/>
    <xacro:property name="joint3lower" value="-2.447"/>
    <xacro:property name="joint3velocity" value="9.08"/>
    <xacro:property name="joint3effort" value="-1"/>

    <!-- Joint 4 -->
    <xacro:property name="joint4upper" value="3.316"/>
    <xacro:property name="joint4lower" value="-3.316"/>
    <xacro:property name="joint4velocity" value="9.60"/>
    <xacro:property name="joint4effort" value="-1"/>

    <!-- Joint 5 -->
    <xacro:property name="joint5upper" value="2.18"/>
    <xacro:property name="joint5lower" value="-2.18"/>
    <xacro:property name="joint5velocity" value="9.51"/>
    <xacro:property name="joint5effort" value="-1"/>

    <!-- Joint 6 -->
    <xacro:property name="joint6upper" value="${2*pi}"/>
    <xacro:property name="joint6lower" value="${-2*pi}"/>
    <xacro:property name="joint6velocity" value="17.45"/>
    <xacro:property name="joint6effort" value="-1"/>

    <!-- fanuc_prism1 -->
    <xacro:property name="fanuc_prism1upper" value="0.05"/>
    <xacro:property name="fanuc_prism1lower" value="-0.05"/>
    <xacro:property name="fanuc_prism1velocity" value="1000"/>
    <xacro:property name="fanuc_prism1effort" value="1000"/>

    <!-- fanuc_prism2 -->
    <xacro:property name="fanuc_prism2upper" value="0.05"/>
    <xacro:property name="fanuc_prism2lower" value="-0.05"/>
    <xacro:property name="fanuc_prism2velocity" value="1000"/>
    <xacro:property name="fanuc_prism2effort" value="1000"/>

    <!-- links -->
    <link name="fanuc_base_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/visual/base_link.stl" />
        </geometry>
        <material name="">
          <color rgba="0.278431372549 0.278431372549 0.278431372549 1.0" />
        </material>
      </visual>
      
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/collision/base_link.stl" />
        </geometry>
      </collision>
      
      <inertial>
        <mass value="0.1" />
        <inertia ixx="0.03" iyy="0.03" izz="0.03" ixy="0.0" ixz="0.0" iyz="0.0" />
      </inertial>
    </link>

    <link name="link_1">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/visual/link_1.stl" />
        </geometry>
        <material name="">
          <color rgba="0.96 0.76 0.13 1.0" />
        </material>
      </visual>
      
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
            <mesh filename="file://$(find fanuc_description)/meshes/collision/link_1.stl" />
        </geometry>
      </collision>
      
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.0226667" ixy="0.0" ixz="0.0" iyy="0.0226667" iyz="0.0" izz="0.0226667" />
      </inertial>
    </link>

    <link name="link_2">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/visual/link_2.stl" />
        </geometry>
        <material name="">
          <color rgba="0.96 0.76 0.13 1.0" />
        </material>
      </visual>

      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/collision/link_2.stl" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.0226667" ixy="0.0" ixz="0.0" iyy="0.0226667" iyz="0.0" izz="0.0226667" />
      </inertial>
    </link>

    <link name="link_3">
        <visual>
          <origin rpy="0 0 0" xyz="0 0 0" />
          <geometry>
              <mesh filename="file://$(find fanuc_description)/meshes/visual/link_3.stl" />
          </geometry>
          <material name="">
              <color rgba="0.96 0.76 0.13 1.0" />
          </material>
        </visual>
        <collision>
          <origin rpy="0 0 0" xyz="0 0 0" />
          <geometry>
              <mesh filename="file://$(find fanuc_description)/meshes/collision/link_3.stl" />
          </geometry>
        </collision>
        <inertial>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <mass value="1" />
          <inertia ixx="0.0226667" ixy="0.0" ixz="0.0" iyy="0.0226667" iyz="0.0" izz="0.0226667" />
        </inertial>
    </link>

    <link name="link_4">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/visual/link_4.stl" />
        </geometry>
        <material name="">
          <color rgba="0.96 0.76 0.13 1.0" />
        </material>
      </visual>

      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/collision/link_4.stl" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.0226667" ixy="0.0" ixz="0.0" iyy="0.0226667" iyz="0.0" izz="0.0226667" />
      </inertial>
    </link>

    <link name="link_5">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/visual/link_5.stl" />
        </geometry>
        <material name="">
          <color rgba="0.96 0.76 0.13 1.0" />
        </material>
      </visual>

      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
            <mesh filename="file://$(find fanuc_description)/meshes/collision/link_5.stl" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.0226667" ixy="0.0" ixz="0.0" iyy="0.0226667" iyz="0.0" izz="0.0226667" />
      </inertial>
    </link>

    <link name="link_6">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_link_6.STL" />
        </geometry>
        <material name="">
            <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
      </visual>

      <collision>
        <origin rpy="0 0 0" xyz="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_link_6.STL" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.0527422480911949 6.99319839614222E-06 -8.7188473017611E-06" rpy="0 0 0" />
        <mass value="4" />
        <inertia ixx="1" ixy="-5.4019E-07" ixz="8.6008E-08" iyy="1" iyz="1.4109E-07" izz="1" />
      </inertial>
    </link>

    <!-- <link name="tool0">
      <visual>
        <origin rpy="0 1.571 0" xyz="-.085 0 0" />
        <geometry>
          <cylinder length="0.17" radius="0.04"/>
        </geometry>
        <material name="">
          <color rgba="0.278431372549 0.278431372549 0.278431372549 1.0" />
        </material>
      </visual>
    </link> -->

    <link name="fanuc_finger_2">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_finger_2.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_finger_2.STL" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.0080676 -0.0097788 -0.012214" rpy="0 0 0" />
        <mass value="3" />
        <inertia ixx="1" ixy="5.4019E-07" ixz="-8.6008E-08" iyy="1" iyz="1.4109E-07" izz="1" />
      </inertial>
    </link>

    <link name="fanuc_finger_1">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_finger_1.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="file://$(find fanuc_description)/meshes/fanuc_finger_1.STL" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="-0.011932 0.0097788 0.012214" rpy="0 0 0" />
        <mass value="3" />
        <inertia ixx="1" ixy="-5.4019E-07" ixz="8.6008E-08" iyy="1" iyz="1.4109E-07" izz="1" />
      </inertial>
    </link>

    <!-- joints --> 
    <joint name = "base_joint_" type = "fixed">
      <origin rpy = "0 0 0" xyz = "0 0 0"/>
      <parent link = "${parent}"/>
      <child link = "fanuc_base_link"/>
    </joint>

    <joint name="joint_1" type="revolute">
        <origin xyz="0 0 0.330" rpy="0 0 0" />
        <parent link="fanuc_base_link" />
        <child link="link_1" />
        <axis xyz="0 0 1" />
        <limit effort="${joint1effort}" lower="${joint1lower}" upper="${joint1upper}" velocity="${joint1velocity}" />
    </joint>
    
    <joint name="joint_2" type="revolute">
        <origin xyz="0.050 0 0" rpy="0 0 0"/>
        <parent link="link_1" />
        <child link="link_2" />
        <axis xyz="0 1 0" />
        <limit effort="${joint2effort}" lower="${joint2lower}" upper="${joint2upper}" velocity="${joint2velocity}" />
    </joint>
    
    <joint name="joint_3" type="revolute">
        <origin xyz="0 0 0.330" rpy="0 0 0"/>
        <parent link="link_2" />
        <child link="link_3" />
        <axis xyz="0 -1 0" />
        <limit effort="${joint3effort}" lower="${joint3lower}" upper="${joint3upper}" velocity="${joint3velocity}" />
    </joint>
    
    <joint name="joint_4" type="revolute">
        <origin xyz="0 0 0.035" rpy="0 0 0"/>
        <parent link="link_3"/>
        <child link="link_4"/>
        <axis xyz="-1 0 0"/>
        <limit effort="${joint4effort}" lower="${joint4lower}" upper="${joint4upper}" velocity="${joint4velocity}" />
    </joint>
    
    <joint name="joint_5" type="revolute">
        <origin xyz="0.335 0 0" rpy="0 0 0"/>
        <parent link="link_4"/>
        <child link="link_5"/>
        <axis xyz="0 -1 0"/>
        <limit effort="${joint5effort}" lower="${joint5lower}" upper="${joint5upper}" velocity="${joint5velocity}" />
    </joint>
    
    <joint name="joint_6" type="revolute">
        <origin xyz="0.080 0 0" rpy="0 0 0"/>
        <parent link="link_5"/>
        <child link="link_6"/>
        <axis xyz="-1 0 0"/>
        <limit effort="${joint6effort}" lower="${joint6lower}" upper="${joint6upper}" velocity="${joint6velocity}" />
    </joint>
<!-- 
    <joint name="tool" type="fixed">
        <origin xyz=".17 0 0" rpy="0 0 0"/>
        <parent link="link_6"/>
        <child link="tool0"/>
    </joint> -->

    <joint name="fanuc_prism1" type="prismatic">
      <origin xyz="0.1401 0.02 0.010995" rpy="3.1416 6.123E-17 1.5708" />
      <parent link="link_6" />
      <child link="fanuc_finger_1" />
      <axis xyz="-1 0 0" />
      <limit effort="${fanuc_prism1effort}" lower="${fanuc_prism1lower}" upper="${fanuc_prism1upper}" velocity="${fanuc_prism1velocity}" />
    </joint>

    <joint name="fanuc_prism2" type="prismatic">
      <origin xyz="0.1401 0 -0.010995" rpy="3.1416 -6.123E-17 -1.5708" />
      <parent link="link_6" />
      <child link="fanuc_finger_2" />
      <axis xyz="1 0 0" />
      <limit effort="${fanuc_prism2effort}" lower="${fanuc_prism2lower}" upper="${fanuc_prism2upper}" velocity="${fanuc_prism2velocity}" />
    </joint>

  </xacro:macro>

</robot>
